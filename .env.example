JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
MEDBIOS_ENCRYPTION_KEY=  # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_API_KEY=          # optional: for Gemini Vision OCR fallback
DATABASE_URL=sqlite+aiosqlite:///./data/medbios.db

# Email / SMTP (optional — critical lab alert emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=your-gmail@gmail.com

# Production (Render)
# DATABASE_URL is auto-injected by Render from the PostgreSQL add-on
# JWT_SECRET_KEY — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# MEDBIOS_ENCRYPTION_KEY — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CORS_ORIGINS=http://localhost:5173,https://med-bios-ai-djn7.vercel.app,https://medbios.vercel.app
